# 生产环境配置文件模板
# 复制此文件为 .env 并根据实际情况修改配置

# ==========================================
# 应用基本配置
# ==========================================
NODE_ENV=production
PORT=3001

# ==========================================
# 数据库配置
# ==========================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=newsapp
DB_PASSWORD=NewsApp@2024
DB_NAME=investment_tools

# 数据库连接池配置
DB_CONNECTION_LIMIT=10
DB_ACQUIRE_TIMEOUT=60000
DB_TIMEOUT=60000

# ==========================================
# 安全配置
# ==========================================
# JWT密钥 - 请务必修改为随机字符串
JWT_SECRET=your-jwt-secret-key-change-this-in-production-environment

# 应用密钥 - 请务必修改为随机字符串
APP_SECRET=your-app-secret-key-change-this-in-production-environment

# 会话密钥
SESSION_SECRET=your-session-secret-key-change-this-in-production

# 密码加密轮数
BCRYPT_ROUNDS=12

# ==========================================
# 日志配置
# ==========================================
LOG_LEVEL=info
LOG_DIR=/var/log/newsapp
LOG_MAX_SIZE=10m
LOG_MAX_FILES=7
LOG_DATE_PATTERN=YYYY-MM-DD

# ==========================================
# 文件上传配置
# ==========================================
UPLOAD_DIR=/opt/newsapp/uploads
MAX_FILE_SIZE=50MB
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx

# ==========================================
# 邮件配置 (可选)
# ==========================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-email-password
# MAIL_FROM=noreply@example.com

# ==========================================
# Redis配置 (可选 - 用于缓存和会话存储)
# ==========================================
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ==========================================
# 外部API配置
# ==========================================
# 企查查API配置
QICHACHA_APP_KEY=
QICHACHA_SECRET_KEY=
QICHACHA_DAILY_LIMIT=100

# 新闻API配置
NEWS_API_URL=
NEWS_API_KEY=

# ==========================================
# 监控和性能配置
# ==========================================
# 启用性能监控
ENABLE_MONITORING=true

# API限流配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 请求超时时间 (毫秒)
REQUEST_TIMEOUT=30000

# ==========================================
# 跨域配置
# ==========================================
CORS_ORIGIN=*
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE
CORS_CREDENTIALS=true

# ==========================================
# SSL/TLS配置
# ==========================================
# 强制HTTPS (当使用反向代理时)
FORCE_HTTPS=false

# 信任代理
TRUST_PROXY=true

# ==========================================
# 定时任务配置
# ==========================================
# 新闻同步定时任务 (cron表达式)
NEWS_SYNC_CRON=0 0 * * *

# 数据备份定时任务
BACKUP_CRON=0 2 * * *

# 日志清理定时任务
LOG_CLEANUP_CRON=0 3 * * 0

# ==========================================
# 缓存配置
# ==========================================
# 缓存过期时间 (秒)
CACHE_TTL=3600

# 静态资源缓存时间
STATIC_CACHE_TTL=86400

# ==========================================
# 健康检查配置
# ==========================================
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=5000

# ==========================================
# 开发调试配置 (生产环境建议关闭)
# ==========================================
DEBUG=false
VERBOSE_LOGGING=false
